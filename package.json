{
    "name": "create-automation-react-app",
    "version": "1.0.0",
    "private": false,
    "type": "module",
    "description": "A reusable React automation project template with rename support.",
    "bin": {
        "create-automation-react-app": "./bin/create-automation-project.mjs"
    },
    "files": [
        ".nvmrc",
        "AGENTS.md",
        "bin",
        "gitignore.template",
        "scripts",
        "src",
        "public",
        "index.html",
        "README.app.md",
        "vite.config.ts",
        "tsconfig.json",
        "tsconfig.app.json",
        "tsconfig.node.json",
        "eslint.config.mjs",
        "README.md"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "rename": "node ./scripts/rename-project.mjs",
        "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "react",
        "vite",
        "template",
        "automation",
        "scaffold"
    ],
    "dependencies": {
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-router": "^7.8.1",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.35.0",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.1.9",
        "@vitejs/plugin-react": "^5.0.2",
        "sass": "^1.80.0",
        "eslint": "^9.35.0",
        "globals": "^16.3.0",
        "typescript": "5.8.3",
        "typescript-eslint": "8.26.1",
        "vite": "^7.1.5",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=22.13.0"
    }
}
